```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js
*.ts
*.tsx
*.css

# Environment variables
.env
.env.local
*.env.*

# Logs
*.log

# Coverage
coverage/
htmlcov/
.coverage

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# OS files
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.tox/

# Node.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Compiled files
*.exe
*.dll
*.so
*.a
*.o
*.obj
*.out

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```