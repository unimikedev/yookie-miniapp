```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.ts.map

# Environment variables
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Temporary files
*.tmp

# Coverage
coverage/
htmlcov/
.coverage

# Python (if applicable)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg-info/
.eggs/

# Compiled JavaScript/TypeScript
lib/
out/
.nyc_output/

# OS generated files
.DS_Store
Thumbs.db

# Testing
.jest/
.nyc_output/
coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
```